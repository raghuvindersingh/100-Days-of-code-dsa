Create and Traverse Singly Linked List

ANS-
class Node:
    def __init__(self, data):
        self.data = data
        self.next = None

# Create Linked List
n = int(input())
arr = list(map(int, input().split()))

head = None
temp = None

for num in arr:
    new_node = Node(num)
    
    if head is None:
        head = new_node
        temp = new_node
    else:
        temp.next = new_node
        temp = new_node

current = head
while current:
    print(current.data, end=" ")
    current = current.next
