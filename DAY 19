-n = int(input())
arr = list(map(int, input().split()))

arr.sort()

left = 0
right = n - 1
min_sum = float('inf')

num1 = 0
num2 = 0

while left < right:
    s = arr[left] + arr[right]
    
    if abs(s) < abs(min_sum):
        min_sum = s
        num1 = arr[left]
        num2 = arr[right]
    
    if s < 0:
        left += 1
    else:
        right -= 1

