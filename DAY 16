Given an array of integers, count the frequency of each distinct element and print the result.

ANS-n = int(input())
arr = list(map(int, input().split()))

freq = {}

for num in arr:
    if num in freq:
        freq[num] += 1
    else:
        freq[num] = 1

for key in freq:
    print(f"{key}:{freq[key]}", end=" ")
